{% extends 'base.html.twig' %}

{% block title %}Tableaux des entrainements{% endblock %}

{% block body %}
<h1>Training index</h1>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>BeginAt</th>
            <th>EndAt</th>
            <th>Title</th>
            <th>Place</th>
            <th>City</th>
            <th>Description</th>
            <th>actions</th>
        </tr>
    </thead>
    <tbody>
        {% for training in trainings %}
        <tr>
            <td>{{ training.id }}</td>
            <td>{{ training.beginAt ? training.beginAt|date('Y-m-d H:i:s') : '' }}</td>
            <td>{{ training.endAt ? training.endAt|date('Y-m-d H:i:s') : '' }}</td>
            <td>{{ training.title }}</td>
            <td>{{ training.place }}</td>
            <td>{{ training.City }}</td>
            <td>{{ training.description }}</td>
            <td>
                <a href="{{ path('app_training_show', {'id': training.id}) }}">show</a>
                <a href="{{ path('app_training_edit', {'id': training.id}) }}">edit</a>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="8">no records found</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<a href="{{ path('app_training_new') }}">Create new</a>
{% endblock %}