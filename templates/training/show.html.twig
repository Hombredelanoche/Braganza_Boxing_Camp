{% extends 'base.html.twig' %}

{% block title %}Training{% endblock %}

{% block body %}
<h1>Training</h1>

<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ training.id }}</td>
        </tr>
        <tr>
            <th>BeginAt</th>
            <td>{{ training.beginAt ? training.beginAt|date('Y-m-d H:i:s') : '' }}</td>
        </tr>
        <tr>
            <th>EndAt</th>
            <td>{{ training.endAt ? training.endAt|date('Y-m-d H:i:s') : '' }}</td>
        </tr>
        <tr>
            <th>Title</th>
            <td>{{ training.title }}</td>
        </tr>
        <tr>
            <th>Place</th>
            <td>{{ training.place }}</td>
        </tr>
        <tr>
            <th>City</th>
            <td>{{ training.City }}</td>
        </tr>
        <tr>
            <th>Description</th>
            <td>{{ training.description }}</td>
        </tr>
    </tbody>
</table>

<a href="{{ path('app_allTraining') }}">back to list</a>

<a href="{{ path('app_training_edit', {'id': training.id}) }}">edit</a>

{{ include('training/_delete_form.html.twig') }}
{% endblock %}